[codespell]
# Ref: https://github.com/codespell-project/codespell#using-a-config-file
skip = .git*,ADDON_DISABLED,.codespellrc,metadata.txt,.venv
check-hidden = true
# camel-cased
ignore-regex = (\b[A-Za-z][a-z]*[A-Z]\S+\b|\.edn\b|\S+…|\\nd\b)
ignore-words-list = vertexes, lupdate, lrelease, Pixmap
